    "import jax\n",
    "import jax.numpy as jnp\n",
    "from custom_jax import forces\n",
    "import numpy as np"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "1d691773",
   "metadata": {},
   "outputs": [],
   "source": [
    "x = jnp.arange(3*1000).reshape(-1,3) * 1.\n",
    "phi = forces.potential(x, np.uint64(1))\n",
    "phi2 = jnp.sum(x**2, axis=-1)\n",
    "\n",
    "print(np.allclose(phi, phi2))"
   ]
